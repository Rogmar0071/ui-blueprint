<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Minimum width of the Projects drawer. On wide screens the drawer may
         expand to half the screen width; this value is the floor. -->
    <dimen name="drawer_min_width">320dp</dimen>
    <dimen name="input_bar_height">52dp</dimen>
    <dimen name="input_bar_radius">26dp</dimen>
    <dimen name="icon_btn_size">40dp</dimen>
    <dimen name="send_btn_size">36dp</dimen>
    <dimen name="card_radius">12dp</dimen>
    <dimen name="message_card_radius">18dp</dimen>

    <!-- Default message card inner padding and text size (user messages). -->
    <dimen name="default_message_card_padding">12dp</dimen>
    <dimen name="default_message_text_size">14sp</dimen>

    <!--
        AI response block dimensions — 80% larger than the defaults above.
          12dp * 1.8 = 21.6dp → 22dp
          14sp * 1.8 = 25.2sp → 25sp
    -->
    <dimen name="ai_response_card_padding">22dp</dimen>
    <dimen name="ai_response_text_size">25sp</dimen>
</resources>
