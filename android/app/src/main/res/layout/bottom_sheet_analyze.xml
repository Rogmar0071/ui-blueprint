<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/analyze_options_title"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="16dp" />

    <!-- Current clip label -->
    <TextView
        android:id="@+id/tvCurrentClip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- No clip hint -->
    <TextView
        android:id="@+id/tvNoClipHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:text="@string/label_no_clip_hint"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Pick a clip button (shown when no clip exists) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickClip"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_pick_clip"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:visibility="gone" />

    <!-- Change clip button (shown when a clip exists) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangeClip"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_change_clip"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnalyzeStandard"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_analyze_standard"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textAllCaps="false" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnalyzeRerun"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_analyze_rerun"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textAllCaps="false" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewLastAnalysis"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_view_last_analysis"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textAllCaps="false" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="4dp" />

    <!-- Additional analysis master toggle -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchAdditionalAnalysis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="@string/label_additional_analysis"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:checked="false" />

    <LinearLayout
        android:id="@+id/layoutAdditionalOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/checkboxKeyframes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_keyframes"
            android:textColor="@color/text_primary"
            android:checked="false" />

        <CheckBox
            android:id="@+id/checkboxOcr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_ocr"
            android:textColor="@color/text_primary"
            android:checked="false" />

        <CheckBox
            android:id="@+id/checkboxTranscript"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_transcript"
            android:textColor="@color/text_primary"
            android:checked="false" />

        <CheckBox
            android:id="@+id/checkboxEvents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_events"
            android:textColor="@color/text_primary"
            android:checked="false" />

        <CheckBox
            android:id="@+id/checkboxSegmentSummaries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_segment_summaries"
            android:textColor="@color/text_primary"
            android:checked="false" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

</LinearLayout>
