<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <!-- ═══════════════════════════════════════════════════════════════════
         Main content
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/black">

        <!-- Custom dark toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/black"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnDrawerToggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="@string/drawer_open"
                app:tint="@color/icon_tint"
                android:scaleType="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSearch"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="@string/btn_search"
                app:tint="@color/icon_tint"
                android:scaleType="center" />
        </LinearLayout>

        <!-- Status strip -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="2dp"
            android:text="@string/status_idle"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBackendUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            tools:text="Backend: https://ui-blueprint-backend.onrender.com" />

        <!-- Multi-select contextual toolbar (hidden by default) -->
        <LinearLayout
            android:id="@+id/toolbarMultiSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical"
            android:background="@color/surface"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSelectionCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                tools:text="2 selected" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectAll"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_select_all"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopySelected"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_copy"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareSelected"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_share"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSelect"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/action_cancel"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Global Chat section label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp"
            android:text="@string/label_global_chat"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="13sp" />

        <!-- Message list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/black"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <!-- Agent mode toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_agent_mode"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAgentMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Input bar pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_input_bar"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnAttach"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:background="@drawable/bg_circle_btn"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/icon_tint"
            android:contentDescription="@string/btn_attach"
            android:scaleType="center" />

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:textColor="@color/text_primary"
                android:hint="@string/hint_reply_main"
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnMic"
                android:layout_width="@dimen/icon_btn_size"
                android:layout_height="@dimen/icon_btn_size"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/icon_tint"
                android:contentDescription="@string/btn_mic"
                android:scaleType="center" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSend"
                android:layout_width="@dimen/send_btn_size"
                android:layout_height="@dimen/send_btn_size"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_send_btn"
                android:src="@android:drawable/ic_menu_upload"
                app:tint="@android:color/black"
                android:contentDescription="@string/btn_send"
                android:scaleType="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         Drawer panel: Projects list (left side, min 320dp)
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="@dimen/drawer_min_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/black"
        android:elevation="8dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_projects"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnCloseDrawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/icon_tint"
                android:contentDescription="@string/drawer_close"
                android:scaleType="center" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/tvProjectsEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="@string/label_projects_empty"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFolders"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewProject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:text="@string/btn_new_project"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
