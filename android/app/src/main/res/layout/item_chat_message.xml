<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for a single chat message row.
  Contains:
    - Role label (You / AI)
    - Message text (normal, or monospace artifact card when ARTIFACT_ blocks present)
    - Always-visible action row: Copy, Share, and (for user messages) Edit
    - Selected overlay for multi-select mode
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="2dp">

    <!-- Message bubble card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Role label -->
            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="11sp"
                android:alpha="0.7"
                android:layout_marginBottom="4dp" />

            <!-- Normal message text -->
            <TextView
                android:id="@+id/tvContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textIsSelectable="true"
                android:lineSpacingMultiplier="1.3" />

            <!-- Artifact block: monospace card (only visible when ARTIFACT_ blocks detected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardArtifact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tvArtifact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textIsSelectable="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyArtifact"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/action_copy_artifact"
                        android:textSize="11sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Always-visible action row -->
    <LinearLayout
        android:id="@+id/rowActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginStart="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopy"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/action_copy"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShare"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/action_share"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/action_edit"
            android:textSize="11sp"
            android:minWidth="0dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
