<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    android:padding="16dp"
    tools:context=".FolderDetailActivity">

    <!-- Folder meta info -->
    <TextView
        android:id="@+id/tvFolderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp"
        tools:text="Folder abc12345" />

    <TextView
        android:id="@+id/tvFolderStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp"
        tools:text="Status: pending" />

    <TextView
        android:id="@+id/tvFolderId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"
        tools:text="ID: 00000000-…" />

    <!-- Action buttons for this project -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRecord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_record"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickGallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_pick_gallery"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyze"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_analyze"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:enabled="false" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvActionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        tools:text="Recording…" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <!-- Jobs section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_jobs"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvJobs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"
        tools:text="analyze – queued (0%)" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <!-- Artifacts section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_artifacts"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvArtifacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"
        tools:text="clip  •  blueprint_json" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <!-- Chat section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_chat"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="120dp"
        android:fillViewport="true"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvChatLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            tools:text="You: Hello\nAI: Hi!" />
    </ScrollView>

    <!-- Input bar pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_bar"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnAttach"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:background="@drawable/bg_circle_btn"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/icon_tint"
            android:contentDescription="@string/btn_attach"
            android:scaleType="center" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:textColor="@color/text_primary"
            android:hint="@string/hint_reply_folder"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMic"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:background="@drawable/bg_circle_btn"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@color/icon_tint"
            android:contentDescription="@string/btn_mic"
            android:scaleType="center" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSend"
            android:layout_width="@dimen/send_btn_size"
            android:layout_height="@dimen/send_btn_size"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_send_btn"
            android:src="@android:drawable/ic_menu_upload"
            app:tint="@android:color/black"
            android:contentDescription="@string/btn_send"
            android:scaleType="center" />
    </LinearLayout>

</LinearLayout>
