<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="6dp"
    tools:context=".FolderDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_surface"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvFolderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Folder abc12345" />

        <TextView
            android:id="@+id/tvFolderStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="Status: pending" />

        <TextView
            android:id="@+id/tvFolderId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            tools:text="ID: 00000000-…" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_card_surface"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_upload_details"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnToggleResourcePanel"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_btn"
                    android:contentDescription="@string/action_maximize_resource"
                    android:rotation="-90"
                    android:scaleType="center"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="@color/icon_tint" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvActionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:accessibilityLiveRegion="polite"
                android:importantForAccessibility="yes"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Recording…" />

            <LinearLayout
                android:id="@+id/layoutResourceBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvUploadGroups"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_surface"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/label_chat"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFolderChatMessages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:minHeight="0dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_bar"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnRecord"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_record"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/icon_tint" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnPickGallery"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_pick_gallery"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/icon_tint" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnAnalyze"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_analyze"
                        android:enabled="false"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/icon_tint" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnRecordAudio20s"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_record_audio_20s"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="@color/icon_tint" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnAttach"
                        android:layout_width="@dimen/icon_btn_size"
                        android:layout_height="@dimen/icon_btn_size"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_attach"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="@color/icon_tint" />

                    <EditText
                        android:id="@+id/etMessage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_reply_folder"
                        android:inputType="textMultiLine"
                        android:maxLines="4"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textColor="@color/text_primary" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnMic"
                        android:layout_width="@dimen/icon_btn_size"
                        android:layout_height="@dimen/icon_btn_size"
                        android:background="@drawable/bg_circle_btn"
                        android:contentDescription="@string/btn_mic"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="@color/icon_tint" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/btnSend"
                        android:layout_width="@dimen/send_btn_size"
                        android:layout_height="@dimen/send_btn_size"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_send_btn"
                        android:contentDescription="@string/btn_send"
                        android:scaleType="center"
                        android:src="@android:drawable/ic_menu_upload"
                        app:tint="@android:color/black" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
