<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/black"
    tools:context=".ChatActivity">

    <!-- Multi-select contextual toolbar (hidden by default) -->
    <LinearLayout
        android:id="@+id/toolbarMultiSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/surface"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="13sp"
            tools:text="2 selected" />

    </LinearLayout>

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/black"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Agent Mode toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_agent_mode"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAgentMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Mode Engine chip selector (multi-select, horizontal scroll) -->
    <HorizontalScrollView
        android:id="@+id/scrollModeChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupModes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipModeStrict"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_strict"
                android:checked="true"
                android:contentDescription="@string/mode_strict_desc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipModePrediction"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_prediction"
                android:contentDescription="@string/mode_prediction_desc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipModeDebug"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_debug"
                android:contentDescription="@string/mode_debug_desc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipModeAudit"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_audit"
                android:contentDescription="@string/mode_audit_desc" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipModeBuilder"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mode_builder"
                android:contentDescription="@string/mode_builder_desc" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Input bar pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_bar"
        android:layout_margin="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnAttach"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:background="@drawable/bg_circle_btn"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/icon_tint"
            android:contentDescription="@string/btn_attach"
            android:scaleType="center" />

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:textColor="@color/text_primary"
            android:hint="@string/hint_reply_main"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <LinearLayout
            android:id="@+id/layoutMultiSelectActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnSelectAll"
                android:layout_width="@dimen/compact_icon_btn_size"
                android:layout_height="@dimen/compact_icon_btn_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_select_all"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_select_all"
                android:tooltipText="@string/action_select_all"
                app:tint="@color/icon_tint" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnCopySelected"
                android:layout_width="@dimen/compact_icon_btn_size"
                android:layout_height="@dimen/compact_icon_btn_size"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_copy"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_copy"
                android:tooltipText="@string/action_copy"
                app:tint="@color/icon_tint" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnShareSelected"
                android:layout_width="@dimen/compact_icon_btn_size"
                android:layout_height="@dimen/compact_icon_btn_size"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_share"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share"
                android:tooltipText="@string/action_share"
                app:tint="@color/icon_tint" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnCancelSelect"
                android:layout_width="@dimen/compact_icon_btn_size"
                android:layout_height="@dimen/compact_icon_btn_size"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_cancel"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_cancel"
                android:tooltipText="@string/action_cancel"
                app:tint="@color/icon_tint" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMic"
            android:layout_width="@dimen/icon_btn_size"
            android:layout_height="@dimen/icon_btn_size"
            android:background="@drawable/bg_circle_btn"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@color/icon_tint"
            android:contentDescription="@string/btn_mic"
            android:scaleType="center" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSend"
            android:layout_width="@dimen/send_btn_size"
            android:layout_height="@dimen/send_btn_size"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_send_btn"
            android:src="@android:drawable/ic_menu_upload"
            app:tint="@android:color/black"
            android:contentDescription="@string/btn_send"
            android:scaleType="center" />
    </LinearLayout>

</LinearLayout>
