<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Row 1: Gallery, Camera, Document, Audio -->
    <LinearLayout
        android:id="@+id/rowAttach1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="16dp">

        <!-- Gallery -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAttachGallery"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="center"
                android:contentDescription="@string/attach_gallery" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach_gallery"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Camera -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAttachCamera"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_menu_camera"
                android:scaleType="center"
                android:contentDescription="@string/attach_camera" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach_camera"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Document -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAttachDocument"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_menu_agenda"
                android:scaleType="center"
                android:contentDescription="@string/attach_document" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach_document"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Audio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAttachAudio"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_btn_speak_now"
                android:scaleType="center"
                android:contentDescription="@string/attach_audio" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach_audio"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- Row 2: Video (shown only in FolderDetailActivity) -->
    <LinearLayout
        android:id="@+id/rowAttach2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <!-- Video -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAttachVideo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_btn"
                android:src="@android:drawable/ic_media_play"
                android:scaleType="center"
                android:contentDescription="@string/attach_video" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/attach_video"
                android:textSize="12sp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Spacer columns to keep alignment with row 1 -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="8dp" />

</LinearLayout>
