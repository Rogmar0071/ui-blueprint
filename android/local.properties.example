# local.properties — copy this file to local.properties and fill in your values.
# DO NOT commit local.properties to source control (it is gitignored by default).

# Full URL of the UI Blueprint backend.
# For the Android emulator pointing at a local server use http://10.0.2.2:8000
# For the hosted backend use e.g. https://ui-blueprint-backend.onrender.com
BACKEND_BASE_URL=https://ui-blueprint-backend.onrender.com

# Bearer token required by the backend API (set via API_KEY on the server).
# This is the backend service token — it is NOT the OpenAI API key.
# Leave blank if the backend is running without authentication (dev mode).
BACKEND_API_KEY=YOUR_API_KEY
